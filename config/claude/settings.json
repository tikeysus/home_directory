{
  "theme": "dark",
  "effortLevel": "medium",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/node /Users/tikeysus/.claude/hooks/block-dangerous-commands.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/node /Users/tikeysus/.claude/hooks/auto-stage.js"
          }
        ]
      }
    ]
  }
}

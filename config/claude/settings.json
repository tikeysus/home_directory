{
  "permissions": {
    "allow": [
      "Bash(gh issue *)",
      "Bash(gh pr *)",
      "Bash(gh repo *)",
      "Bash(gh run *)",
      "Bash(gh release *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git status)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(git remote *)"
    ]
  },
  "model": "haiku",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/node /Users/tikeysus/.claude/hooks/block-dangerous-commands.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/node /Users/tikeysus/.claude/hooks/auto-stage.js"
          }
        ]
      }
    ]
  },
  "effortLevel": "medium",
  "theme": "dark"
}

#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage:
  debug [--build-only] [--run] source.c [-- program args...]
  debug [--build-only] [--run] source.cpp [-- program args...]
  debug [--run] ./existing-executable [-- program args...]

Compiles supported source files with debug symbols into build/debug/ and opens LLDB.
EOF
}

if [[ $# -eq 0 || "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

build_only=false
run_immediately=false
debug_c_flags=(-g -O0 -fno-omit-frame-pointer -Wall -Wextra)
debug_cxx_flags=(-g -O0 -fno-omit-frame-pointer -Wall -Wextra -std=c++20)

while [[ $# -gt 0 ]]; do
  case "$1" in
    --build-only)
      build_only=true
      shift
      ;;
    --run)
      run_immediately=true
      shift
      ;;
    --)
      break
      ;;
    -*)
      echo "Unknown option: $1"
      exit 1
      ;;
    *)
      break
      ;;
  esac
done

if [[ $# -eq 0 ]]; then
  usage
  exit 1
fi

input="$1"
shift

program_args=()
if [[ "${1:-}" == "--" ]]; then
  shift
  program_args=("$@")
elif [[ $# -gt 0 ]]; then
  echo "Pass program arguments after --"
  exit 1
fi

if [[ ! -e "$input" ]]; then
  echo "Not found: $input"
  exit 1
fi

mkdir -p build/debug

case "$input" in
  *.c)
    name="$(basename "${input%.c}")"
    out="build/debug/$name"
    clang "${debug_c_flags[@]}" "$input" -o "$out"
    ;;
  *.cc|*.cpp|*.cxx)
    name="$(basename "${input%.*}")"
    out="build/debug/$name"
    clang++ "${debug_cxx_flags[@]}" "$input" -o "$out"
    ;;
  *)
    if [[ -x "$input" && ! -d "$input" ]]; then
      out="$input"
    else
      echo "Expected a .c/.cc/.cpp/.cxx source file or an executable"
      exit 1
    fi
    ;;
esac

echo "LLDB target: $out"
if [[ "$build_only" == true ]]; then
  exit 0
elif [[ "$run_immediately" == true && ${#program_args[@]} -gt 0 ]]; then
  lldb -o run -- "$out" "${program_args[@]}"
elif [[ "$run_immediately" == true ]]; then
  lldb -o run "$out"
elif [[ ${#program_args[@]} -gt 0 ]]; then
  lldb -- "$out" "${program_args[@]}"
else
  lldb "$out"
fi
